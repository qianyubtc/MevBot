{
  "name": "mevbot-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "build:bin": "tsx build.ts",
    "build:bin:mac-arm64": "tsx build.ts mac-arm64",
    "build:bin:win": "tsx build.ts win-x64",
    "build:bin:linux": "tsx build.ts linux-x64"
  },
  "pkg": {
    "assets": [
      ".env.example"
    ],
    "outputPath": "dist-bin"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "viem": "^2.17.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
