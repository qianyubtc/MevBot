{
  "name": "oc-superbot-app",
  "version": "0.4.2",
  "description": "OC SuperBot — On-chain MEV trading desktop app",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"tsc -w\" \"electron .\"",
    "build": "tsc",
    "start": "electron .",
    "pack:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win",
    "pack:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.onchainsuperbot.app",
    "productName": "OC SuperBot",
    "icon": "assets/icon",
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "ui/**/*",
      "assets/**/*",
      "!dist/mac${/*}",
      "!dist/mac-arm64${/*}",
      "!dist/win-unpacked${/*}",
      "!dist/linux-unpacked${/*}",
      "!dist/*.dmg",
      "!dist/*.blockmap",
      "!dist/*.yml",
      "!dist/*.exe",
      "!dist/*.AppImage",
      "!dist/builder-*"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "assets/icon.icns",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [{ "target": "AppImage", "arch": ["x64"] }]
    }
  },
  "dependencies": {
    "viem": "^2.17.0",
    "ws": "^8.18.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12"
  }
}
